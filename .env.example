# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development           # development | production
APP_SECRET_KEY=change-me-in-production-to-random-32-char-string
LOG_LEVEL=INFO

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=claudbot
POSTGRES_USER=claudbot
POSTGRES_PASSWORD=your_secure_password_here

# Constructed by the app automatically – you can also override directly
# DATABASE_URL=postgresql+asyncpg://claudbot:password@localhost:5432/claudbot
# SYNC_DATABASE_URL=postgresql+psycopg2://claudbot:password@localhost:5432/claudbot

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── LLM (choose one provider) ───────────────────────────────────────────────
# Option 1 – OpenRouter (supports Claude, Gemini, GPT-4, etc.)
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx
LLM_MODEL=openrouter/anthropic/claude-3.5-sonnet

# Option 2 – Anthropic directly
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
# LLM_MODEL=claude-3-5-sonnet-20241022

# Option 3 – Google Gemini
# GOOGLE_API_KEY=AIxxxxxxxxxxxxxxxx
# LLM_MODEL=gemini/gemini-1.5-pro

# LLM request settings
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096
LLM_MAX_RETRIES=3

# ─── LLM Router (multi-model routing) ────────────────────────────────────────
# Assign different models to different task tiers.
# Leave any tier empty to fall back to LLM_MODEL.
#
# Tier usage:
#   STRONG   → write_code, debug_code                (complex reasoning)
#   CREATIVE → campaigns, emails, blogs, websites     (creative writing)
#   FAST     → social posts, brand save, simple tasks (cheap & quick)
#   (default LLM_MODEL is used for: documents, explanations, SEO)
#
LLM_MODEL_STRONG=openrouter/anthropic/claude-opus-4-5
LLM_MODEL_CREATIVE=openrouter/anthropic/claude-sonnet-4-5
LLM_MODEL_FAST=openrouter/google/gemini-flash-1.5

# Set to true to let a routing LLM dynamically upgrade/downgrade tiers
# based on actual task complexity (uses LLM_MODEL_FAST for the routing call)
LLM_ROUTER_ENABLED=false
LLM_ROUTER_MODEL=   # leave blank to use LLM_MODEL_FAST

# ─── Web search ───────────────────────────────────────────────────────────────
# At least one key is required to use web_search / research_topic.
# Tavily is preferred (built for LLM agents). Serper is the fallback.
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxx
# SERPER_API_KEY=xxxxxxxxxxxxxxxxxxxx

# ─── Document reader ──────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads   # Place PDFs / text files here for read_document

# ─── Image generation (DALL-E 3) ─────────────────────────────────────────────
# Required only if you want generate_image to work
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
IMAGE_OUTPUT_DIR=./output/images       # Where generated images are saved locally

# ─── Web builder output ───────────────────────────────────────────────────────
WEB_OUTPUT_DIR=./output/websites       # Where generated HTML files are saved

# ─── Email (SMTP) – used by email_writer tool ─────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=your@email.com

# ─── Safety ───────────────────────────────────────────────────────────────────
# Comma-separated list of tool names that require human approval before running
APPROVAL_REQUIRED_TOOLS=send_email,delete_data,bulk_update

# ─── Celery ───────────────────────────────────────────────────────────────────
CELERY_CONCURRENCY=4
